# Cargo build output (root workspace target/ and any stray per-crate target/).
target/
# Reference clones — re-clone via the URLs in HANDOFF.md, not committed.
/refs
**/*.rs.bk
.DS_Store

# runtime snapshot output
/snapshot/
/snapshot.tmp/
/snapshot2/
/snapshot_smp/
/vmnetsnap/
# snapshot stores (--store dir, default ./vmstore; restore_test uses ./vmstore-test,
# diff_snapshot_test uses ./vmstore-difftest)
/vmstore/
/vmstore-test/
/vmstore-difftest/
# snapshot artifacts (any --store/--snap-dir name) — never source files
memory.bin
gic.bin
disk.img
vmstate.json
manifest.json
